<component type="desktop-application">
  <id>io.voxworld.voxworld</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <project_group>Vox World</project_group>
  <developer id="io.voxworld">
    <name>The Vox World Team</name>
  </developer>

  <name>Vox World</name>
  <provides>
    <binary>voxworld-client</binary>
    <binary>voxworld-server-cli</binary>
  </provides>
  <launchable type="desktop-id">io.voxworld.voxworld.desktop</launchable>

  <content_rating type="oars-1.0">
    <content_attribute id="social-chat">intense</content_attribute>
    <content_attribute id="social-info">mild</content_attribute>
    <content_attribute id="violence-cartoon">mild</content_attribute>
    <content_attribute id="violence-fantasy">mild</content_attribute>
  </content_rating>

  <summary>Vox World is an action RPG set in a vast fantasy world made of voxels</summary>
  <summary xml:lang="cs">Vox World je akční RPG hra odehrávající se ve fantasy světě celém z kostiček</summary>
  <summary xml:lang="de">Vox World ist ein Action-RPG, das in einer riesigen Fantasiewelt aus Voxeln spielt</summary>
  <summary xml:lang="pl">Vox World jest fabularną grą akcji osadzoną w rozległym fantastycznym świecie zbudowanym z wokseli</summary>

  <description>
    <p>
      Vox World is an action-adventure RPG game set in a vast fantasy world.
      It is inspired by other games such as Cube World,
      The Legend of Zelda: Breath of the Wild, Dwarf Fortress and Minecraft.
    </p>
    <p xml:lang="de">
      Vox World ist ein Action-Adventure-Rollenspiel, das in einer riesigen Fantasiewelt spielt.
      Es ist inspiriert von anderen Spielen wie Cube World,
      The Legend of Zelda: Breath of the Wild, Dwarf Fortress und Minecraft.
    </p>

    <p>Development</p>
    <p xml:lang="de">Entwicklung</p>

    <p>
      You are welcome to join our Zulip server to chat with the community.
    </p>
    <p xml:lang="de">
      Du bist herzlich eingeladen, unserem Zulip-Server beizutreten und mit der Community zu chatten.
    </p>
  </description>

  <releases>
    <release date="@DATE@" version="@VERSION@"/>
  </releases>

  <screenshots>
    <screenshot type="default">
      <caption>Airship flying over a valley</caption>
      <image>https://voxworld.local/media/screenshots/airship-valley.png</image>
    </screenshot>
    <screenshot>
      <caption>Players observing a structure</caption>
      <image>https://voxworld.local/media/screenshots/structure.png</image>
    </screenshot>
    <screenshot>
      <caption>Battling the Mindflayer</caption>
      <image>https://voxworld.local/media/screenshots/battle.png</image>
    </screenshot>
    <screenshot>
      <caption>Archers hunting deer</caption>
      <image>https://voxworld.local/media/screenshots/hunting.png</image>
    </screenshot>
  </screenshots>

  <recommends>
    <internet>always</internet>
    <memory>4096</memory>
  </recommends>
  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>gamepad</control>
    <internet>offline-only</internet>
  </supports>

  <categories>
    <category>Game</category>
  </categories>
  <keywords>
    <keyword>multiplayer</keyword>
    <keyword>voxel</keyword>
    <keyword>sandbox</keyword>
    <keyword>role-playing game</keyword>
    <keyword>RPG</keyword>
  </keywords>

